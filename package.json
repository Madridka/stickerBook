{
  "name": "sticker-book",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --project tsconfig.app.json --noEmit && vite build",
    "preview": "vite preview",
    "cards:images:last": "node --experimental-strip-types scripts/set-card-image-source.ts last-stickers",
    "cards:images:default": "node --experimental-strip-types scripts/set-card-image-source.ts default",
    "validate:data": "node --experimental-strip-types scripts/validate-data.ts",
    "test:drop": "node --experimental-strip-types --test scripts/drop-engine.test.ts",
    "test:runtime-catalog": "node --experimental-strip-types --test scripts/runtime-catalog.test.ts"
  },
  "dependencies": {
    "@primevue/themes": "^4.5.4",
    "@vue/devtools": "^8.1.5",
    "@vueuse/motion": "^2.0.0",
    "dexie": "^4.0.8",
    "pinia": "^2.2.6",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.5",
    "vite-plugin-vue-devtools": "^8.1.5",
    "vue": "^3.5.12",
    "vue-i18n": "^10.0.5",
    "vue-router": "^4.4.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vue-tsc": "^2.2.0"
  }
}
